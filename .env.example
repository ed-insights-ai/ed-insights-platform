# =============================================================================
# Supabase (Cloud) — used by apps/web for authentication
# Create a free project at https://supabase.com and copy these values
# from Settings > API in your Supabase dashboard.
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# =============================================================================
# Local Postgres — used by apps/api and packages/pipeline for data storage
# Homebrew Postgres 15 on default port 5432, socket auth (no password).
# Database: ed_insights | User: lume
# For psycopg2 (pipeline): postgresql://lume@localhost:5432/ed_insights
# For asyncpg (API):        postgresql+asyncpg://lume@localhost:5432/ed_insights
# =============================================================================
DATABASE_URL=postgresql+asyncpg://lume@localhost:5432/ed_insights

# =============================================================================
# API — backend URL for the frontend to call
# =============================================================================
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# CORS — comma-separated list of allowed origins for the API
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://web:3000
